# Dodo Payments API key
DODO_PAYMENTS_API_KEY=your_dodo_api_key_here

# Google Drive folder IDs as JSON string
# Example: {"crop": "folder_id_1", "livestock": "folder_id_2", "mixed": "folder_id_3", "default": "folder_id_4"}
GOOGLE_DRIVE_FOLDER_IDS={}

# Secret key for webhook signature verification
SECRET_KEY=your_webhook_secret_here

# Self URL for ping (set to your Render URL in production)
SELF_URL=http://localhost:8000

# Database path (optional, defaults to subscriptions.db)
DATABASE_PATH=subscriptions.db

# Port (optional, defaults to 8000)
PORT=8000
